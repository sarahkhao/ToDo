<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Réglages"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_preferences" />
        <Button
            android:id="@+id/btnAjouterTache"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Créer une nouvelle tâche" />

    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Filtrer par : " />
        <Spinner android:id="@+id/spinnerFiltre" android:layout_width="match_parent" android:layout_height="wrap_content" />
    </LinearLayout>

    <ListView android:id="@+id/listViewTaches" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="16dp"/>
</LinearLayout>